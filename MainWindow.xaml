<Window x:Class="Animation_Demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Animation_Demo"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" Loaded="Window_Loaded">
    <Canvas>
        <Polyline 
            Points="51,155 51,199 466,199 466,340 320,340"
            Opacity="0.5"
            Stroke="Silver"
            StrokeThickness="12" RenderTransformOrigin="0.181,0.813"
            />
        <Polyline 
            x:Name="myPolyine"
            Points="51,155 51,199 466,199 466,340 320,340"
            Opacity="0.5"
            Stroke="Orange"
            StrokeThickness="6" RenderTransformOrigin="0.981,0.813"
            />
        <Button x:Name="Btn_switch" Content="打开" Canvas.Left="608" Canvas.Top="84" Click="Btn_switch_Click"/>
        <Button x:Name="Btn_close" Content="关闭" Canvas.Left="408" Canvas.Top="84" Click="Btn_close_Click"/>
    </Canvas>
</Window>
